{{ ansible_managed | comment }}
[Unit]
Description="Muffin's Cache Mover Script."
After=network.target

[Service]
Type=oneshot
User={{ cache_mover_user }}
Group={{ cache_mover_group }}
ExecStart=/usr/bin/python3 "{{ cache_mover_dir }}/cache-mover.py"
WorkingDirectory={{ cache_mover_dir }}

[Install]
WantedBy=multi-user.target
